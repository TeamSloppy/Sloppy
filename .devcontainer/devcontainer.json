{
  "name": "Sloppy",
  "build": {
    "context": "..",
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/workspaces/Sloppy",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/Sloppy,type=bind,consistency=cached",
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt", "seccomp=unconfined"
  ],
  "postCreateCommand": "swift package resolve && cd Dashboard && npm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "swiftlang.swift-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
