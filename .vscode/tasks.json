{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docker: Build",
      "type": "shell",
      "command": "bash",
      "args": ["${workspaceFolder}/utils/docker/scripts/build.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
    },
    {
      "label": "Docker: Up",
      "type": "shell",
      "command": "bash",
      "args": ["${workspaceFolder}/utils/docker/scripts/up.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "dedicated" },
    },
    {
      "label": "Docker: Down",
      "type": "shell",
      "command": "bash",
      "args": ["${workspaceFolder}/utils/docker/scripts/down.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared" },
    },
    {
      "label": "Docker: Build and Up",
      "dependsOrder": "sequence",
      "dependsOn": ["Docker: Build", "Docker: Up"],
      "group": "none",
    },
    {
      "label": "Local: Build Sloppy",
      "type": "shell",
      "command": "swift",
      "args": ["build", "--product", "Sloppy"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
    },
    {
      "label": "Local: Run Sloppy",
      "type": "shell",
      "command": "swift",
      "args": ["run", "sloppy", "run"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" },
    },
    {
      "label": "Local: Dashboard Dev",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "options": { "cwd": "${workspaceFolder}/Dashboard" },
      "group": "none",
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" },
    },
    {
      "label": "Local: Sloppy + Dashboard",
      "dependsOn": ["Local: Run Sloppy", "Local: Dashboard Dev"],
      "group": "none",
      "presentation": { "reveal": "always" },
    },
    {
      "label": "Local: Build and Run Sloppy + Dashboard",
      "dependsOrder": "sequence",
      "dependsOn": ["Local: Build Sloppy", "Local: Sloppy + Dashboard"],
      "group": "none",
    },
    {
      "label": "swift: Build Debug Sloppy TUI",
      "type": "process",
      "command": "/usr/bin/swift",
      "args": ["build", "--product", "sloppy"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
    },
    {
      "label": "swift: Build Release Sloppy TUI",
      "type": "process",
      "command": "/usr/bin/swift",
      "args": ["build", "-c", "release", "--product", "sloppy"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
    },
    {
      "label": "swift: Run Debug Sloppy TUI in Terminal.app",
      "type": "process",
      "command": "/bin/bash",
      "args": [
        "-lc",
        "set -euo pipefail\npidfile=\"${workspaceFolder}/.build/sloppy-tui.pid\"\nlldbfile=\"${workspaceFolder}/.build/sloppy-tui-attach.lldb\"\n/bin/rm -f \"$pidfile\" \"$lldbfile\"\n/usr/bin/osascript -e 'tell application \"Terminal\" to do script \"cd \" & quoted form of \"${workspaceFolder}\" & \" && printf %s $$ > .build/sloppy-tui.pid && exec ./.build/debug/sloppy tui\"'\nfor _ in {1..80}; do\n  if [[ -s \"$pidfile\" ]]; then\n    pid=\"$(/bin/cat \"$pidfile\")\"\n    if kill -0 \"$pid\" 2>/dev/null && /bin/ps -p \"$pid\" -o command= | /usr/bin/grep -q 'sloppy tui'; then\n      printf 'target create \"%s/.build/debug/sloppy\"\\nprocess attach --pid %s\\n' \"${workspaceFolder}\" \"$pid\" > \"$lldbfile\"\n      exit 0\n    fi\n  fi\n  /bin/sleep 0.1\ndone\necho \"Timed out waiting for sloppy tui to start in Terminal.app\" >&2\nexit 1",
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "dependsOrder": "sequence",
      "dependsOn": ["swift: Build Debug Sloppy TUI"],
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared" },
    },
  ],
}
